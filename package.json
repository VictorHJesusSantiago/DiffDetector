{
  "name": "doc-drift-detector",
  "version": "1.0.0",
  "description": "Detector de drift entre documentação (README/runbooks/wikis) e o sistema real (código/infraestrutura).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "drift": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-sql.mjs",
    "dev": "tsx src/api/server.ts",
    "scan": "tsx src/cli/index.ts scan",
    "cli": "tsx src/cli/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "audit:ci": "npm audit --audit-level=high",
    "verify": "npm run typecheck && npm run lint && npm run test:coverage && npm run audit:ci"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fast-glob": "^3.3.2",
    "pg": "^8.13.1",
    "typescript": "^5.6.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
