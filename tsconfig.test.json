{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["src", "test", "vitest.config.ts"],
  // `exclude` é herdado do tsconfig base, que exclui "test" — sem sobrescrever aqui, os arquivos
  // de teste ficam fora do programa e nem o tsc nem o ESLint com informação de tipos os enxergam.
  "exclude": ["node_modules", "dist", "coverage"]
}
