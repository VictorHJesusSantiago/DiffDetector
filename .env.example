# Obrigatória para qualquer comando que persista scans (scan sem --no-save, history, latest,
# diff, dashboard) e para a API. Sem ela o processo falha na inicialização, em vez de tentar
# uma conexão padrão silenciosa.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/drift_detector

PORT=3000

# Raízes que a API pode escanear, separadas por vírgula. Sem esta variável o padrão é apenas o
# diretório de trabalho do processo. O POST /scans recebe caminhos do cliente e devolve trechos
# das linhas encontradas: fora dessas raízes, isso seria leitura arbitrária de arquivos do host.
DRIFT_ALLOWED_ROOTS=.

# Token de acesso à API (Authorization: Bearer <token>). Enquanto não definido, a API fica sem
# autenticação e só deve ser exposta em loopback.
# DRIFT_API_TOKEN=troque-por-um-segredo-aleatorio-longo
